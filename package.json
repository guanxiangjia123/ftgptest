{
  "name": "nfticket",
  "version": "1.0.0",
  "description": "Anti-Scalping NFT Ticketing System",
  "scripts": {
    "compile": "hardhat compile && cp artifacts/contracts/NFTicket.sol/NFTicket.json frontend/src/contract/NFTicketABI.json",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "verify": "hardhat verify --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.0"
  }
}
